    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "rate-limit-redis": "^4.2.0",
    "redis": "^4.6.12",
    "stripe": "^14.17.0",
    "uuid": "^9.0.1",
